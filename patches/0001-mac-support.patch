+        /// <summary>
+        /// Returns a sensible display name for a pack at the given path.
+        /// Aspyr's macOS Sims 2 install names each EP folder with a ".localized"
+        /// or ".app" suffix (e.g. "Pets.localized" or "Pets.app"); strip the
+        /// suffix so the name matches PackPathResolver's dictionary entries
+        /// ("Pets", "University", "Bon Voyage", "Family Fun Stuff", ...).
+        /// For non-Mac layouts we fall back to the leaf folder name as-is.
+        /// </summary>
+        private static string GetFriendlyPackName(string packPath)
+        {
+            string leaf = Path.GetFileName(packPath) ?? packPath;
+
+            // Aspyr's classic layout: TSData lives directly inside e.g.
+            // "Pets.localized" or "Family Fun Stuff.localized".
+            if (leaf.EndsWith(".localized", StringComparison.OrdinalIgnoreCase))
+                return leaf.Substring(0, leaf.Length - ".localized".Length);
+            if (leaf.EndsWith(".app", StringComparison.OrdinalIgnoreCase))
+                return leaf.Substring(0, leaf.Length - ".app".Length);
+
+            // Aspyr alt layout where TSData is one level deeper at .../<X>.app/Contents/Assets:
+            // walk up looking for a .localized or .app ancestor.
+            if (string.Equals(leaf, "Assets", StringComparison.OrdinalIgnoreCase))
+            {
+                string current = packPath;
+                for (int i = 0; i < 4; i++)
+                {
+                    string parent;
+                    try { parent = Path.GetDirectoryName(current); } catch { parent = null; }
+                    if (string.IsNullOrEmpty(parent)) break;
+                    string name = Path.GetFileName(parent) ?? "";
+                    if (name.EndsWith(".localized", StringComparison.OrdinalIgnoreCase))
+                        return name.Substring(0, name.Length - ".localized".Length);
+                    if (name.EndsWith(".app", StringComparison.OrdinalIgnoreCase))
+                        return name.Substring(0, name.Length - ".app".Length);
+                    current = parent;
+                }
+            }
+
+            return leaf;
+        }
     }
 }
 
